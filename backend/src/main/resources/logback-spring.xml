<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Source root log level from Spring property; fall back to INFO if not set -->
    <springProperty name="LOG_LEVEL" source="logging.level.root" defaultValue="INFO"/>

    <!-- ================================================================
         Local / Test profile: human-readable console output
         ================================================================ -->
    <springProfile name="local,test">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [%X{requestId}] %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="${LOG_LEVEL}">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- ================================================================
         Production profile: structured JSON output via AsyncAppender +
         rolling file appender.
         NOTE: Retention is set to 30 days / 100 MB per file.
         TBD: Confirm final retention period with compliance/legal stakeholder
              in accordance with the organization's data retention policy.
         ================================================================ -->
    <springProfile name="prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
        </appender>

        <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/psy-assistant.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <!-- Daily rollover; keep 30 days; max 100 MB per file -->
                <fileNamePattern>logs/psy-assistant.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
        </appender>

        <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
            <!-- Drop DEBUG/TRACE messages when queue is 80 % full (default); keep WARN/ERROR -->
            <discardingThreshold>20</discardingThreshold>
            <queueSize>512</queueSize>
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="JSON_FILE"/>
        </appender>

        <root level="${LOG_LEVEL}">
            <appender-ref ref="ASYNC"/>
        </root>
    </springProfile>

</configuration>
